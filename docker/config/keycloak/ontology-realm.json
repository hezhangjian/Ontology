{
  "realm": "ontology",
  "enabled": true,
  "displayName": "Ontology Platform",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": true,
  "roles": {
    "realm": [
      { "name": "Admin", "description": "Platform administrator" },
      { "name": "Builder", "description": "Platform builder" },
      { "name": "Viewer", "description": "Platform viewer" }
    ]
  },
  "clients": [
    {
      "clientId": "ontology-portal",
      "name": "Ontology Portal",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "${PORTAL_PUBLIC_URL}/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "${PORTAL_PUBLIC_URL}",
        "http://localhost:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "${PORTAL_PUBLIC_URL}/*##http://localhost:3000/*"
      },
      "defaultClientScopes": ["email", "profile", "roles", "web-origins"]
    }
  ],
  "groups": [
    { "name": "platform-admins", "realmRoles": ["Admin", "Builder", "Viewer"] },
    { "name": "platform-builders", "realmRoles": ["Builder", "Viewer"] },
    { "name": "platform-viewers", "realmRoles": ["Viewer"] }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@ontology.local",
      "emailVerified": true,
      "firstName": "平台",
      "lastName": "管理员",
      "groups": ["/platform-admins"],
      "credentials": [{ "type": "password", "value": "${DEMO_ADMIN_PASSWORD}", "temporary": false }]
    },
    {
      "username": "builder",
      "enabled": true,
      "email": "builder@ontology.local",
      "emailVerified": true,
      "firstName": "平台",
      "lastName": "构建者",
      "groups": ["/platform-builders"],
      "credentials": [{ "type": "password", "value": "${DEMO_BUILDER_PASSWORD}", "temporary": false }]
    },
    {
      "username": "viewer",
      "enabled": true,
      "email": "viewer@ontology.local",
      "emailVerified": true,
      "firstName": "平台",
      "lastName": "查看者",
      "groups": ["/platform-viewers"],
      "credentials": [{ "type": "password", "value": "${DEMO_VIEWER_PASSWORD}", "temporary": false }]
    }
  ]
}
